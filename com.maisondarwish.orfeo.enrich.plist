<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.maisondarwish.orfeo.enrich</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/naeldarwish/automation-orfeo/serveur_enrichissement.py</string>
    </array>

    <key>WorkingDirectory</key>
